{
  "manifest_version": 3,
  "name": "LinkedIn Scroll Fix",
  "description": "An unofficial extension to fix slow scrolling on LinkedIn.",
  "version": "0.0.0",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-scroll-fix@humarotta",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
